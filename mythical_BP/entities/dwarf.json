{
  "format_version": "1.26.20",
  "minecraft:entity": {
    "description": {
      "identifier": "mythicalcreatures:dwarf",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },

    "component_groups": {
      "dwarf_skin_0": { "minecraft:skin_id": { "value": 0 } },
      "dwarf_skin_1": { "minecraft:skin_id": { "value": 1 } },
      "dwarf_skin_2": { "minecraft:skin_id": { "value": 2 } },
      "dwarf_skin_3": { "minecraft:skin_id": { "value": 3 } },
      "dwarf_skin_4": { "minecraft:skin_id": { "value": 4 } },
      "dwarf_skin_5": { "minecraft:skin_id": { "value": 5 } },

      "desert_dwarf":  { "minecraft:mark_variant": { "value": 1 } },
      "jungle_dwarf":  { "minecraft:mark_variant": { "value": 2 } },
      "savanna_dwarf": { "minecraft:mark_variant": { "value": 3 } },
      "snow_dwarf":    { "minecraft:mark_variant": { "value": 4 } },
      "swamp_dwarf":   { "minecraft:mark_variant": { "value": 5 } },
      "taiga_dwarf":   { "minecraft:mark_variant": { "value": 6 } }
    },

    "components": {
      "minecraft:type_family": {
        "family": [ "dwarf", "mob" ]
      },
      "minecraft:variant": {
        "value": 0
      },
      "minecraft:mark_variant": {
        "value": 0
      },
      "minecraft:skin_id": {
        "value": 0
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": { "test": "in_lava", "subject": "self", "operator": "==", "value": true },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.7
      },
      "minecraft:nameable": {},
      "minecraft:movement": {
        "value": 0.5
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "can_pass_doors": true,
        "can_open_doors": true,
        "avoid_water": true
      },
      "minecraft:annotation.open_door": {},
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:follow_range": {
        "value": 128
      },
      "minecraft:attack": {
        "damage": {
          "range_min": 7,
          "range_max": 10
        }
      },
      "minecraft:persistent": {},
      "minecraft:physics": {},
      "minecraft:pushable_by_entity": {},
      "minecraft:pushable_by_block": {},

      "minecraft:behavior.float": {
        "priority": 0
      },
      "minecraft:behavior.melee_attack": {
        "priority": 1,
        "track_target": true,
        "speed_multiplier": 0.6
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 2,
        "entity_types": {
          "filters": { "test": "is_family", "subject": "other", "operator": "!=", "value": "creeper" }
        }
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 3,
        "reselect_targets": true,
        "must_see": true,
        "within_radius": 25,
        "entity_types": [
          {
            "filters": {
              "all_of": [
                { "test": "is_family", "subject": "other", "value": "monster" },
                { "test": "is_family", "subject": "other", "operator": "!=", "value": "creeper" }
              ]
            },
            "max_dist": 35,
            "must_see": true
          }
        ]
      },
      "minecraft:behavior.look_at_player": {
        "priority": 8,
        "look_distance": 8,
        "probability": 0.02
      },
      "minecraft:behavior.random_stroll": {
        "priority": 10,
        "speed_multiplier": 0.6
      }
    },

    "events": {
      "minecraft:entity_spawned": {
        "sequence": [
          {
            "filters": { "test": "has_component", "operator": "!=", "value": "minecraft:skin_id_set" },
            "randomize": [
              { "weight": 1, "add": { "component_groups": [ "dwarf_skin_0" ] } },
              { "weight": 1, "add": { "component_groups": [ "dwarf_skin_1" ] } },
              { "weight": 1, "add": { "component_groups": [ "dwarf_skin_2" ] } },
              { "weight": 1, "add": { "component_groups": [ "dwarf_skin_3" ] } },
              { "weight": 1, "add": { "component_groups": [ "dwarf_skin_4" ] } },
              { "weight": 1, "add": { "component_groups": [ "dwarf_skin_5" ] } }
            ]
          },
          {
            "filters": {
              "any_of": [
                { "test": "has_biome_tag", "value": "desert" },
                { "test": "has_biome_tag", "value": "mesa" }
              ]
            },
            "add": { "component_groups": [ "desert_dwarf" ] }
          },
          {
            "filters": { "test": "has_biome_tag", "value": "jungle" },
            "add": { "component_groups": [ "jungle_dwarf" ] }
          },
          {
            "filters": { "test": "has_biome_tag", "value": "savanna" },
            "add": { "component_groups": [ "savanna_dwarf" ] }
          },
          {
            "filters": {
              "any_of": [
                {
                  "all_of": [
                    { "test": "has_biome_tag", "value": "cold" },
                    { "test": "has_biome_tag", "operator": "!=", "value": "ocean" }
                  ]
                },
                { "test": "has_biome_tag", "value": "frozen" }
              ]
            },
            "add": { "component_groups": [ "snow_dwarf" ] }
          },
          {
            "filters": { "test": "has_biome_tag", "value": "swamp" },
            "add": { "component_groups": [ "swamp_dwarf" ] }
          },
          {
            "filters": {
              "all_of": [
                {
                  "any_of": [
                    { "test": "has_biome_tag", "value": "taiga" },
                    { "test": "has_biome_tag", "value": "extreme_hills" }
                  ]
                },
                { "test": "has_biome_tag", "operator": "!=", "value": "cold" }
              ]
            },
            "add": { "component_groups": [ "taiga_dwarf" ] }
          }
        ]
      }
    }
  }
}
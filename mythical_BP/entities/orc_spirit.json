{
  "format_version": "1.26.20",
  "minecraft:entity": {
    "description": {
      "identifier": "mythicalcreatures:orc_spirit",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },

    "component_groups": {
      "emerging": {
        "minecraft:behavior.emerge": {
          "duration": 5.0,
          "on_done": {
            "event": "finish_emerge",
            "target": "self"
          }
        },
        "minecraft:damage_sensor": {
          "triggers": [
            { "cause": "all", "deals_damage": "no" }
          ]
        },
        "minecraft:knockback_resistance": { "value": 1.0, "max": 1.0 }
      },

      "active": {
        "minecraft:behavior.melee_box_attack": {
          "priority": 2,
          "track_target": true,
          "speed_multiplier": 1.0,
          "cooldown_time": 1.5
        },
        "minecraft:behavior.nearest_attackable_target": {
            "priority": 2,
            "must_see": true,
            "reselect_targets": true,
            "within_radius": 25.0,
            "must_see_forget_duration": 17.0,
            "entity_types": [
            {
                "filters": {
                "any_of": [
                    { "test": "is_family", "subject": "other", "value": "player" },
                    { "test": "is_family", "subject": "other", "value": "snowgolem" },
                    { "test": "is_family", "subject": "other", "value": "irongolem" }
                ]
                },
                "max_dist": 35
            },
            {
                "filters": {
                "any_of": [
                    { "test": "is_family", "subject": "other", "value": "villager" },
                    { "test": "is_family", "subject": "other", "value": "wandering_trader" },
                    { "test": "is_family", "subject": "other", "value": "dwarf" }
                ]
                },
                "max_dist": 35,
                "must_see": false
            }
            ]
        },
        "minecraft:behavior.hurt_by_target": {
          "priority": 2,
          "entity_types": {
            "filters": { "test": "is_family", "subject": "other", "operator": "!=", "value": "greenskin" }
          }
        },
        "minecraft:target_nearby_sensor": {
          "inside_range": 35.0,
          "outside_range": 36.0,
          "must_see": false,
          "on_inside_range": {
            "event": "spirit_has_target",
            "target": "self"
          },
          "on_outside_range": {
            "event": "spirit_lost_target",
            "target": "self"
          }
        }
      },

      "no_target": {
        "minecraft:timer": {
          "looping": false,
          "time": 10.0,
          "time_down_event": {
            "event": "start_dig",
            "target": "self"
          }
        }
      },

      "has_target": {

      },

      "digging": {
        "minecraft:damage_sensor": {
          "triggers": [
            { "cause": "all", "deals_damage": "no" }
          ]
        },
        "minecraft:behavior.dig": {
            "duration": 5.0,
            "idle_time": 0,
            "priority": 1
        },
				"minecraft:timer": {
					"looping": false,
					"time": 5.0,
					"time_down_event": { "event": "finish_dig", "target": "self" }
				},
        "minecraft:knockback_resistance": { "value": 1.0, "max": 1.0 }
      },
      "spirit_weapon_0": {
        "minecraft:skin_id": { "value": 0 }
      },
      "spirit_weapon_1": {
        "minecraft:skin_id": { "value": 1 },
        "minecraft:loot": { "table": "loot_tables/entities/orc_spirit_axe.json" }
      },
      "spirit_weapon_2": {
        "minecraft:skin_id": { "value": 2 },
        "minecraft:loot": { "table": "loot_tables/entities/orc_spirit_trident.json" }
      },
      "spirit_weapon_3": {
        "minecraft:skin_id": { "value": 3 },
        "minecraft:loot": { "table": "loot_tables/entities/orc_spirit_spear.json" }
      },

      "spirit_rot_0": { "minecraft:variant": { "value": 0 } },
      "spirit_rot_1": { "minecraft:variant": { "value": 1 } },
      "spirit_rot_2": { "minecraft:variant": { "value": 2 } },
      "spirit_rot_3": { "minecraft:variant": { "value": 3 } },

      "spirit_infection_0": { "minecraft:mark_variant": { "value": 0 } },
      "spirit_infection_1": { "minecraft:mark_variant": { "value": 1 } },
      "spirit_infection_2": { "minecraft:mark_variant": { "value": 2 } },
      "spirit_infection_3": { "minecraft:mark_variant": { "value": 3 } },

      "despawn_now": {
        "minecraft:instant_despawn": {}
      }
    },

    "components": {
      "minecraft:type_family": {
        "family": [ "orc_spirit", "orc", "greenskin", "undead", "mob" ]
      },

      "minecraft:health": {
        "value": 38,
        "max": 38
      },
      "minecraft:attack": {
        "damage": 9
      },
      "minecraft:movement": {
        "value": 0.2
      },
      "minecraft:knockback_resistance": {
        "value": 0.4
      },
      "minecraft:collision_box": {
        "width": 1.2,
        "height": 2.7
      },
      "minecraft:follow_range": {
        "value": 64
      },
      "minecraft:experience_reward": {
        "on_death": "query.last_hit_by_player ? 5 : 0"
      },

      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_water": true
      },
      "minecraft:fire_immune": {},
      "minecraft:nameable": {},
      "minecraft:persistent": {},
      "minecraft:physics": {},
      "minecraft:pushable_by_entity": {},
      "minecraft:pushable_by_block": {},

      "minecraft:navigation.walk": {
        "can_path_over_water": false,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},

      "minecraft:behavior.float": {
        "priority": 0
      }
    },

    "events": {
      "minecraft:entity_spawned": {
        "sequence": [
          {
            "randomize": [
              { "weight": 1, "add": { "component_groups": [ "spirit_weapon_0" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_weapon_1" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_weapon_2" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_weapon_3" ] } }
            ]
          },
          {
            "randomize": [
              { "weight": 1, "add": { "component_groups": [ "spirit_rot_0" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_rot_1" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_rot_2" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_rot_3" ] } }
            ]
          },
          {
            "randomize": [
              { "weight": 1, "add": { "component_groups": [ "spirit_infection_0" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_infection_1" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_infection_2" ] } },
              { "weight": 1, "add": { "component_groups": [ "spirit_infection_3" ] } }
            ]
          },
          {
            "add": { "component_groups": [ "emerging" ] }
          }
        ]
      },

      "finish_emerge": {
        "remove": { "component_groups": [ "emerging" ] },
        "add": { "component_groups": [ "active", "no_target" ] }
      },
      
      "spirit_has_target": {
        "remove": {
          "component_groups": [ "no_target"]
        },
        "add": {
          "component_groups": [ "has_target" ]
        }
      },

      "spirit_lost_target": {
        "remove": {
          "component_groups": [ "has_target" ]
        },
        "add": {
          "component_groups": [ "no_target"]
        }
      },

      "start_dig": {
        "remove": { "component_groups": [ "active" ] },
        "add": { "component_groups": [ "digging" ] }
      },

      "finish_dig": {
        "add": { "component_groups": [ "despawn_now" ] }
      }
    }
  }
}